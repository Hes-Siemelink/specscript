<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence noisy libraries -->
    <logger name="io.ktor" level="WARN"/>
    <logger name="io.modelcontextprotocol" level="WARN"/>
    <logger name="io.javalin" level="WARN"/>
    <logger name="org.eclipse.jetty" level="WARN"/>

    <!-- MCP SDK FeatureRegistry uses custom logger names "FeatureRegistry[Type]" -->
    <!-- Logback hierarchy uses dot-separators, so brackets don't create parent-child relationships -->
    <logger name="FeatureRegistry[Tool]" level="WARN"/>
    <logger name="FeatureRegistry[Resource]" level="WARN"/>
    <logger name="FeatureRegistry[Prompt]" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
